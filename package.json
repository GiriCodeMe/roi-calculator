{
  "name": "roi-calculator",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "test:e2e": "playwright test",
    "test:a11y": "playwright test e2e/accessibility.spec.js",
    "build:coverage": "cross-env VITE_COVERAGE=true vite build",
    "test:e2e:coverage": "cross-env VITE_COVERAGE=true playwright test",
    "report:e2e:coverage": "nyc report",
    "check:e2e:coverage": "nyc check-coverage",
    "e2e:coverage": "npm run build:coverage && npm run test:e2e:coverage && npm run report:e2e:coverage && npm run check:e2e:coverage"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.15.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.1.2",
    "cross-env": "^10.1.0",
    "eslint": "^10.2.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "jsdom": "^29.0.1",
    "nyc": "^18.0.0",
    "vite": "^6.0.0",
    "vite-plugin-istanbul": "^8.0.0",
    "vitest": "^4.1.2"
  }
}
